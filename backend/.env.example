# Copy to .env (or set in your shell / Task Scheduler task). None are required
# to start the API; the engine needs ANTHROPIC_API_KEY + Gmail creds to run.
ANTHROPIC_API_KEY=sk-ant-...
TAVILY_API_KEY=tvly-...    # Tavily Search API key for JD lookups (optional; enables blocked-source eval)
SERPAPI_API_KEY=...        # SerpApi key (optional); google_jobs fallback when Tavily's JD is thin/stub-like
# SERPAPI_MAX_LOOKUPS=30   # per-run cap on paid SerpApi fallbacks
# TAVILY_MAX_LOOKUPS=60    # per-run cap on Tavily lookups
JOBSEARCH_DIR=C:\Users\maryk\OneDrive\Documents\job-search
# JOBSEARCH_DB=./jobsearch.db
# JOBSEARCH_HOURS=24
# JOBSEARCH_SKIP_CLAUDE=0
